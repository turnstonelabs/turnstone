      "get": {
        "summary": "Global SSE event stream",
        "operationId": "v1_api_events_global_get",
        "tags": [
          "Streaming"
        ],
        "description": "Global Server-Sent Events stream for state-change broadcasts across all workstreams. Returns text/event-stream.",
